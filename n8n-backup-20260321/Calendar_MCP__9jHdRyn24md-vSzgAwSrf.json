nda.\n\nComo preencher o JSON final\n\nSe você só consultou: calendar_action=\"check_availability\"\n\nSe você criou: calendar_action=\"create\" e preencher event.id e event.title\n\nSe você atualizou: calendar_action=\"update\" e preencher event.id\n\nSe você cancelou: calendar_action=\"delete\" e preencher event.id\n\nSe não mexeu em agenda: calendar_action=\"none\"\n\nlabels_next sempre atualizado (ex.: etapa_agendando enquanto negocia; etapa_agendado quando criou; etapa_confirmado quando o paciente confirma presença)ul assistant"}},"type":"@n8n/n8n-nodes-langchain.agent","typeVersion":3.1,"position":[-480,96],"id":"4a4caedd-d39b-4811-b924-5eeecc3c9674","name":"AI Agent1"},{"parameters":{"descriptionType":"manual","toolDescription":"Sempre busque a disponibilidade da agenda do médico pelo id, olhando de agora até os próximos 21 dias.\n\nPara sugerir agendas, sempre sugira nos dias mais próximos disponiveis. e sempre em horários comerciais 8am até as 18pm.","resource":"calendar","calendar":{"__rl":true,"value":"fabiohhsales@gmail.com","mode":"id"},"timeMax":"={{ $now.plus(21, 'days') }}","options":{}},"type":"n8n-nodes-base.googleCalendarTool","typeVersion":1.3,"position":[-256,416],"id":"ce77a67b-588f-42b5-a304-0f976ef4bd1f","name":"GC_CheckAvailability","credentials":{"googleCalendarOAuth2Api":{"id":"HE4F00ldoDcETyPG","name":"Google Calendar account"}}},{"parameters":{"operation":"getAll","calendar":{"__rl":true,"value":"={{ /*n8n-auto-generated-fromAI-override*/ $fromAI('Calendar', ``, 'string') }}","mode":"id","__regex":"(^[a-zA-Z0-9.!#$%&’*+/=?^_`{|}~-]+@[a-zA-Z0-9-]+(?:\\.[a-zA-Z0-9-]+)*)"},"limit":"={{ /*n8n-auto-generated-fromAI-override*/ $fromAI('Limit', ``, 'number') }}","timeMin":"={{ /*n8n-auto-generated-fromAI-override*/ $fromAI('After', ``, 'string') }}","timeMax":"={{ /*n8n-auto-generated-fromAI-override*/ $fromAI('Before', ``, 'string') }}","options":{}},"type":"n8n-nodes-base.googleCalendarTool","typeVersion":1.3,"position":[-96,496],"id":"fc1461