 valorProcurado,\n    total_itens_verificados: itensSupabase.length\n  }\n};"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[576,752],"id":"87f2c5eb-ad90-4e9e-a758-ce1554cc3002","name":"Code in JavaScript"},{"parameters":{"rules":{"values":[{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":3},"conditions":[{"leftValue":"={{ $json.encontrou_duplicidade }}","rightValue":true,"operator":{"type":"boolean","operation":"equals"},"id":"b14aa168-481d-48e4-a1d7-c813c8e4d3e0"}],"combinator":"and"},"renameOutput":true,"outputKey":"duplicidade"},{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":3},"conditions":[{"id":"9e97adc8-208d-4eb1-ad81-3df8850c8043","leftValue":"={{ $json.encontrou_duplicidade }}","rightValue":false,"operator":{"type":"boolean","operation":"equals"}}],"combinator":"and"},"renameOutput":true,"outputKey":"nao duplicata"}]},"options":{}},"type":"n8n-nodes-base.switch","typeVersion":3.4,"position":[800,752],"id":"b07a0f69-5f64-4b76-abe0-693db7fef431","name":"Switch2"},{"parameters":{"tableId":"messages","fieldsUi":{"fieldValues":[{"fieldId":"id","fieldValue":"={{ $json.id }}"},{"fieldId":"chatwoot_message_id","fieldValue":"88888888"},{"fieldId":"conversation_id","fieldValue":"={{ $('Busca Mensagenspor Source Id').last().json.conversation_id }}"},{"fieldId":"content","fieldValue":"={{ $('Edit Fields').last().json.body.conversation.messages[0].content }}"},{"fieldId":"content_type","fieldValue":"={{ $('Edit Fields').last().json.body.conversation.messages[0].content_type }}"},{"fieldId":"sender_type","fieldValue":"={{ $('Edit Fields').last().json.body.conversation.messages[0].sender_type }}"},{"fieldId":"created_at","fieldValue":"={{ $('Edit Fields').last().json.body.conversation.messages[0].updated_at }}"},{"fieldId":"from_who","fieldValue":"human"},{"fieldId":"chatwoot_conversation_id","fieldValue":"={{ $('Filtra In ou Out going').last().json.body.convers